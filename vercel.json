{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/[[...path]].js": {
      "maxDuration": 10,
      "includeFiles": "backend/dist/**",
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    { "source": "/((?!api/|assets/|favicon\\.svg|\\.css|\\.js|\\.png|\\.jpg|\\.ico).*)", "destination": "/index.html" }
  ]
}
